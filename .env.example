# ============================================================
# NOC Sentinel Lab — Environment Variables Template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# Azure
VM_PUBLIC_IP=YOUR_VM_PUBLIC_IP

# PostgreSQL (shared by FastAPI app and Zabbix)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=noc_lab
POSTGRES_USER=noc_user
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# Zabbix (separate DB on same PostgreSQL instance)
ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=YOUR_ZABBIX_DB_PASSWORD
ZBX_SERVER_HOST=zabbix-server
ZBX_SERVER_NAME=NOC-Sentinel-Lab

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD
GF_SERVER_ROOT_URL=http://${VM_PUBLIC_IP}:3000

# AlertManager — Gmail SMTP (use App Password, not main password)
# Generate at: https://myaccount.google.com/apppasswords
ALERTMANAGER_SMTP_FROM=YOUR_EMAIL@gmail.com
ALERTMANAGER_SMTP_PASSWORD=YOUR_GMAIL_APP_PASSWORD
ALERTMANAGER_RECEIVER_EMAIL=YOUR_EMAIL@gmail.com

# Jira Cloud
# Get API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://YOUR_SITE.atlassian.net
JIRA_EMAIL=YOUR_EMAIL@gmail.com
JIRA_API_TOKEN=YOUR_JIRA_API_TOKEN
JIRA_PROJECT_KEY=NOC
